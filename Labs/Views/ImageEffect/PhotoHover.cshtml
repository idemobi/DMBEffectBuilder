@{
    Layout = "_Layout";
    string DocUrl(string c) =>
        $"/Documentation/Show?packageId=DMBEffectBuilder&groupName=NuGet&namespaceName=DMBEffectBuilder&objectName={c}";
}

@using (Html.SectionBuilder().SetHeight(125, UnitSize.px).BootstrapBackgroundEffect(VariantStyle.Normal).Begin())
{
    @using (Html.FlexBlockBuilder().SetAlignItemsCenter().SetJustifyContentCenter().Begin())
    {
        @using (Html.BlockBuilder().AsTextCenter().Begin())
        {
            @Html.TitleBuilder().SetTitle("Photo & Hover Effects", TitleLevel.One).Render()
            @using (Html.PB_P().AsMuted().Begin())
            {
                @:Hover over each image to see the effect in action
            }
            @Html.Button(ActionItemFactory.Url(title: "Back to Catalog", url: "/ImageEffect/Index", icon: IconStruct.Bootstrap(value: "bi-arrow-left")).SetVariant(VariantStyle.Primary)).Render()
        }
    }
}

@using (Html.RowBuilder().SetGap(Gap.G4).SetPadding(SpacingSide.X, SpacingSize.Three).SetPadding(SpacingSide.Y, SpacingSize.Four).Begin())
{
    @* ── Simple Hover ── *@
    @await Html.PartialAsync("_ImageEffectCard", new ImageEffectCardViewModel
    {
        Title = "Fade", Icon = "bi-cursor",
        Description = "Basic visibility effect triggered on hover. Fades the image opacity.",
        Usage = "Subtle interactions, grid hover.",
        DocUrl = DocUrl(nameof(FadeHoverEffect_ImageExtension)),
        ImageContent = Html.ImageRender("/images/test/landscape.png").SetWidth(100, UnitSize.percent).SetHeight(180, UnitSize.px).InMediaComponent(m => m.SetStyle("object-fit", "cover")).FadeHoverEffect()
    })

    @await Html.PartialAsync("_ImageEffectCard", new ImageEffectCardViewModel
    {
        Title = "Grayscale", Icon = "bi-palette",
        Description = "Turns the image to grayscale on hover for a classic interaction.",
