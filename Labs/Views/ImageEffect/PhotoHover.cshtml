        ImageContent = Html.ImageRender("/images/test/portrait.png").SetWidth(100, UnitSize.percent).SetHeight(180, UnitSize.px).InMediaComponent(m => m.SetStyle("object-fit", "cover")).GrayscaleHoverEffect()
