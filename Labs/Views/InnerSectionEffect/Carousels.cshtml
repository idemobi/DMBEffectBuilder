@using (Html.BlockBuilder().AsCarouselWrapper().Begin())
{
    @using (Html.BlockBuilder().AsSectionSubLabel(largeMargin: true).Begin())
    {
        @Html.TitleBuilder().SetTitle("Flat · Horizontal marquee · Hover scale + pause", TitleLevel.Six).AsSubSectionTitle().Render()
    }
    @(Html.CylinderCarouselBuilder()
        .SetShape(CylinderShapeMode.Flat)
        .SetHoverScale()
        .SetSpeed(20)
        .SetCardWidth("13em")
        .SetAspectRatio("3/4")
        .AddImageCard("https://picsum.photos/seed/11/390/520", "photo 1")
        .AddImageCard("https://picsum.photos/seed/22/390/520", "photo 2")
        .AddImageCard("https://picsum.photos/seed/33/390/520", "photo 3")
