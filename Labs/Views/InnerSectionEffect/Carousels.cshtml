@* ── Filmstrip Reveal ── *@
@using (Html.BlockBuilder().AsSectionHeader().Begin())
{
    @using (Html.BlockBuilder().Begin())
    {
        @Html.TitleBuilder().SetTitle("Filmstrip Reveal", TitleLevel.Three).Render()
        @using (Html.PB_P().AsMuted().Begin())
        {
            @:Full-viewport cinematic hero: images scroll as a strip, the center one scales to fullscreen, then the title and thumbnail slideshow are revealed.
        }
    }
    @Html.Button(ActionItemFactory.Url(title: "", url: DocUrl(nameof(FilmstripRevealEffect_InnerExtensions)), icon: IconStruct.Bootstrap("bi-book-half")).SetVariant(VariantStyle.Secondary).SetOutlined()).Render()
}

@(Html.FilmstripRevealBuilder()
    .SetTitle("Filmstrip Reveal")
    .SetBackgroundColor("#1a1a1a")
    .SetForegroundColor("#f4f4f4")
    .AddSlide("/images/test/fight.png",     "Combat — le duel")
    .AddSlide("/images/test/rest.png",      "Repos — après la bataille")
    .AddSlide("/images/test/forest6.png",   "Forêt — ombre et lumière")
    .AddSlide("/images/test/forest1.png",   "Forêt — l'aube")
    .AddSlide("/images/test/terranova.png", "Terra Nova — monde ouvert"))
