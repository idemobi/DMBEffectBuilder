@using DMBBootstrapBuilder
@using DMBComponentBuilder
@using DMBEffectBuilder
@using DMBPageBuilder
@{
    Layout = "_Layout";
}

@* ── Hero ── *@
@using (Html.SectionBuilder().SetHeight(125, UnitSize.px).BootstrapBackgroundEffect(VariantStyle.Normal).Begin())
{
    @using (Html.FlexBlockBuilder().SetAlignItemsCenter().SetJustifyContentCenter().Begin())
    {
        @using (Html.BlockBuilder().AsTextCenter().Begin())
        {
            @Html.TitleBuilder().SetTitle("Introduction — EffectBuilder", TitleLevel.One).Render()
            @using (Html.PB_P().AsLead().Begin())
            {
                @:Giving life to your components with simple Fluent API extensions.
            }
            @using (Html.FlexBlockBuilder().SetJustifyContentCenter().WithGap(Old_Gap.Gap2).Begin())
            {
                @Html.Button(ActionItemFactory.AspRoute("EffectBuilder", "GettingStarted").SetTitle("Get Started").SetIcon(IconStruct.Bootstrap("bi-play-fill")).SetVariant(VariantStyle.Primary)).Render()
                @Html.Button(ActionItemFactory.AspRoute("ImageEffect", "Index").SetTitle("Browse Effects").SetIcon(IconStruct.Bootstrap("bi-grid")).SetVariant(VariantStyle.Secondary).SetOutlined()).Render()
            }
        }
    }
}

@* ── 3 piliers visuels ── *@
@using (Html.BlockBuilder().AsSectionContentTop().Begin())
{
    @using (Html.RowBuilder().AsPillarGrid().Begin())
    {
        @using (Html.ColBuilder().SetCol(ColSize.Col12).SetCol(ColSize.Col4, ResponsiveBreakpoint.Md).Begin())
        {
            @using (Html.BlockBuilder().AsSidebarCard().Begin())
            {
                @using (Html.BlockBuilder().AsPaddedBlock().Begin())
                {
                    @using (Html.PB_Span().AddClass("bi bi-code-slash fs-2 text-primary d-block mb-2").Begin()) { }
                    @using (Html.PB_Span().AsSemiBold().Begin())
                    {
                        @:Fluent C# API
                    }
                    @using (Html.PB_P().AsSmallMuted().AsNoMargin().Begin())
                    {
                        @:Chain effects directly on your builders — one method, one effect.
                    }
                }
            }
        }
        @using (Html.ColBuilder().SetCol(ColSize.Col12).SetCol(ColSize.Col4, ResponsiveBreakpoint.Md).Begin())
        {
            @using (Html.BlockBuilder().AsSidebarCard().Begin())
            {
                @using (Html.BlockBuilder().AsPaddedBlock().Begin())
                {
                    @using (Html.PB_Span().AddClass("bi bi-lightning-charge-fill fs-2 text-warning d-block mb-2").Begin()) { }
                    @using (Html.PB_Span().AsSemiBold().Begin())
                    {
                        @:Zero CSS overhead
                    }
                    @using (Html.PB_P().AsSmallMuted().AsNoMargin().Begin())
                    {
                        @:Only the stylesheets for effects you call are injected — nothing more.
                    }
                }
            }
        }
        @using (Html.ColBuilder().SetCol(ColSize.Col12).SetCol(ColSize.Col4, ResponsiveBreakpoint.Md).Begin())
        {
            @using (Html.BlockBuilder().AsSidebarCard().Begin())
            {
                @using (Html.BlockBuilder().AsPaddedBlock().Begin())
                {
                    @using (Html.PB_Span().AddClass("bi bi-layers-fill fs-2 text-success d-block mb-2").Begin()) { }
                    @using (Html.PB_Span().AsSemiBold().Begin())
                    {
                        @:Fully combinable
                    }
                    @using (Html.PB_P().AsSmallMuted().AsNoMargin().Begin())
                    {
                        @:Stack multiple effects — classes and CSS variables merge without collision.
                    }
                }
            }
        }
    }
}

@* ── What is + aperçu live ── *@
@using (Html.BlockBuilder().AsSectionContent().Begin())
{
    @using (Html.RowBuilder().SetGapY(Gap.G5).SetAlignItems(AlignItems.Center).Begin())
    {
        @using (Html.ColBuilder().SetCol(ColSize.Col12).SetCol(ColSize.Col7, ResponsiveBreakpoint.Lg).Begin())
        {
            @Html.TitleBuilder().SetTitle("What is EffectBuilder?", TitleLevel.Two).AsSectionHeading().Render()
            @using (Html.PB_P().Begin())
            {
                @using (Html.PB_Span().AsBold().Begin())
                {
                    @:EffectBuilder
                }
                @: is a module within the DMB Page Builder ecosystem. Instead of managing
                @: CSS files and class names, you apply effects directly in C# using a chainable Fluent API.
                @: The system automatically injects only the stylesheets your page actually needs.
            }
            @using (Html.BlockBuilder().AsBenefitRow().Begin())
            {
                @using (Html.PB_Span().AddClass("bi bi-check-circle-fill text-success me-3 mt-1").Begin()) { }
                @using (Html.BlockBuilder().Begin())
                {
                    @:Works on
                    @using (Html.PB_Span().AsMonospace().Begin())
                    {
                        @:ImageRenderBuilder
                    }
                    @:,
                    @using (Html.PB_Span().AsMonospace().Begin())
                    {
                        @:SectionBuilder
                    }
                    @: and
                    @using (Html.PB_Span().AsMonospace().Begin())
                    {
                        @:InnerSectionBuilder
                    }
                }
            }
            @using (Html.BlockBuilder().AsBenefitRow().Begin())
            {
                @using (Html.PB_Span().AddClass("bi bi-check-circle-fill text-success me-3 mt-1").Begin()) { }
                @using (Html.BlockBuilder().Begin())
                {
                    @:Every parameter is a named argument injected as a CSS variable
                }
            }
            @using (Html.BlockBuilder().AsBenefitRow().Begin())
            {
                @using (Html.PB_Span().AddClass("bi bi-check-circle-fill text-success me-3 mt-1").Begin()) { }
                @using (Html.BlockBuilder().Begin())
                {
                    @:Stack multiple effects without any class name collision
                }
            }
        }
        @using (Html.ColBuilder().SetCol(ColSize.Col12).SetCol(ColSize.Col5, ResponsiveBreakpoint.Lg).Begin())
        {
            @using (Html.BlockBuilder().AsSidebarCard().Begin())
            {
                @using (Html.BlockBuilder().AsPreviewWrapper().Begin())
                {
                    @Html.ImageRender("/images/test/landscape.png").SetWidth(100, UnitSize.percent).ShineSweepEffect().Render()
                }
                @using (Html.BlockBuilder().AsPaddedBlock().Begin())
                {
                    @(Html.CodeBlock(@"@@Html.ImageRender(""..."").ShineSweepEffect()", CodeLanguage.CSharp))
                    @using (Html.PB_P().AsSmallMuted().AsNoMargin().Begin())
                    {
                        @:Hover the image to see the effect.
                    }
                }
            }
        }
    }
}

@* ── Three Effect Families ── *@
@using (Html.BlockBuilder().AsSectionContent().Begin())
{
    @using (Html.BlockBuilder().AsTextCenter().Begin())
    {
        @Html.TitleBuilder().SetTitle("Three Effect Families", TitleLevel.Two).AsSectionHeading().Render()
        @using (Html.PB_P().AsMuted().Begin())
        {
            @:Each family targets a different layer of your layout.
        }
    }
    @using (Html.RowBuilder().AsPillarGrid().Begin())
    {
        @using (Html.ColBuilder().SetCol(ColSize.Col12).SetCol(ColSize.Col4, ResponsiveBreakpoint.Md).Begin())
        {
            @using (Html.BlockBuilder().AsPillarCard().Begin())
            {
                @using (Html.BlockBuilder().AsPreviewWrapper().Begin())
                {
                    @Html.ImageRender("/images/test/forest1.png").SetWidth(100, UnitSize.percent).SetStyle("height", "180px").SetStyle("object-fit", "cover").GrayscaleHoverEffect().Render()
                }
                @using (Html.BlockBuilder().AsTopMargin().Begin())
                {
                    @using (Html.PB_Span().AddClass("bi bi-image text-primary me-1").Begin()) { }
                    @Html.TitleBuilder().SetTitle("Image Effects", TitleLevel.Five).AsCompact().Render()
                }
                @using (Html.PB_P().AsSmallMuted().Begin())
                {
                    @:30+ effects on
                    @using (Html.PB_Span().AsMonospace().Begin())
                    {
                        @:ImageRenderBuilder
                    }
                    @: — hover, filter, glow, glitch and more.
                }
                @using (Html.PB_Span().AsMonospaceSmall().Begin())
                {
                    @:.GrayscaleHoverEffect()
                }
            }
        }
        @using (Html.ColBuilder().SetCol(ColSize.Col12).SetCol(ColSize.Col4, ResponsiveBreakpoint.Md).Begin())
        {
            @using (Html.BlockBuilder().AsPillarCard().Begin())
            {
                @using (Html.BlockBuilder().AsPreviewWrapper().Begin())
                {
                    @Html.ImageRender("/images/test/terranova.png").SetWidth(100, UnitSize.percent).SetHeight(180, UnitSize.px).InMediaComponent(m => m.SetStyle("object-fit", "cover")).ZoomHoverEffect(scale: 1.08).Render()
                }
                @using (Html.BlockBuilder().AsTopMargin().Begin())
                {
                    @using (Html.PB_Span().AddClass("bi bi-layout-sidebar text-success me-1").Begin()) { }
                    @Html.TitleBuilder().SetTitle("Section Effects", TitleLevel.Five).AsCompact().Render()
                }
                @using (Html.PB_P().AsSmallMuted().Begin())
                {
                    @:Animated backgrounds on
                    @using (Html.PB_Span().AsMonospace().Begin())
                    {
                        @:SectionBuilder
                    }
                    @: — Aurora, Starfield, Glass and more.
                }
                @using (Html.PB_Span().AsMonospaceSmall().Begin())
                {
                    @:.AuroraEffect()
                }
            }
        }
        @using (Html.ColBuilder().SetCol(ColSize.Col12).SetCol(ColSize.Col4, ResponsiveBreakpoint.Md).Begin())
        {
            @using (Html.BlockBuilder().AsPillarCard().Begin())
            {
                @using (Html.BlockBuilder().AsPreviewWrapper().Begin())
                {
                    @Html.ImageRender("/images/test/portrait.png").SetWidth(100, UnitSize.percent).SetStyle("height", "180px").SetStyle("object-fit", "cover").FocusSpotEffect().Render()
                }
                @using (Html.BlockBuilder().AsTopMargin().Begin())
                {
                    @using (Html.PB_Span().AddClass("bi bi-layers text-warning me-1").Begin()) { }
                    @Html.TitleBuilder().SetTitle("Inner Sections", TitleLevel.Five).AsCompact().Render()
                }
                @using (Html.PB_P().AsSmallMuted().Begin())
                {
                    @:Interactions inside sections — CardFlip, Timeline, Fan and more.
                }
                @using (Html.PB_Span().AsMonospaceSmall().Begin())
                {
                    @:.CardFlipEffect()
                }
            }
        }
    }
}

@* ── Philosophy ── *@
@using (Html.BlockBuilder().AsSectionContent().Begin())
{
    @using (Html.FlexBlockBuilder().WithGap(Old_Gap.Gap3).SetAlignItemsStretch().Begin())
    {
        @using (Html.BlockBuilder().AsInfoCallout().SetStyle("margin", "0").SetStyle("flex", "2").Begin())
        {
            @using (Html.FlexBlockBuilder().Begin())
            {
                @using (Html.BlockBuilder().AsCalloutIcon().Begin())
                {
                    @using (Html.PB_Span().AddClass("bi bi-lightbulb-fill fs-2 text-info").Begin()) { }
                }
                @using (Html.BlockBuilder().Begin())
                {
                    @Html.TitleBuilder().SetTitle("Design for intent, not implementation", TitleLevel.Four).AsAlertHeading().Render()
                    @using (Html.PB_P().AsNoMargin().Begin())
                    {
                        @:Write
                        @using (Html.PB_Span().AsMonospace().Begin())
                        {
                            @:.GrayscaleHoverEffect()
                        }
                        @: and you express
                        @using (Html.PB_Span().AsItalic().Begin())
                        {
                            @:what you want
                        }
                        @:, not how to build it. EffectBuilder handles the CSS, transitions, and performance automatically.
                    }
                }
            }
        }
        @using (Html.BlockBuilder().AsSidebarCard().SetStyle("flex", "1").Begin())
        {
            @using (Html.BlockBuilder().AsPaddedBlock().SetStyle("height", "100%").Begin())
            {
                @using (Html.FlexBlockBuilder().SetFlexColumn().SetAlignItemsStart().SetJustifyContentCenter().SetStyle("height", "100%").Begin())
                {
                    @Html.TitleBuilder().SetTitle("Next Step", TitleLevel.Five).Render()
                    @using (Html.PB_P().AsSmallMuted().Begin())
                    {
                        @:Learn how to install and use EffectBuilder in minutes.
                    }
                    @Html.Button(ActionItemFactory.AspRoute("EffectBuilder", "GettingStarted").SetTitle("Getting Started").SetIcon(IconStruct.Bootstrap("bi-play-fill")).SetVariant(VariantStyle.Primary)).Render()
                }
            }
        }
    }
}
