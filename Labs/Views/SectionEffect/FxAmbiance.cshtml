        Usage = "Retro, editorial, cinematic sections.",
        EffectAction = s => s.AnimatedGradientEffect("#1a1a2e", "#16213e", 135m, 6m).NoiseEffect(0.20m, 0.35m),
        DocUrl = DocUrl(nameof(NoiseEffect_SectionExtensions))
    })

    @* 3. Spotlight *@
    @await Html.PartialAsync("_EffectCard", new EffectCardViewModel
