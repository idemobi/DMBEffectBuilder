@{
    Layout = "_Layout";
    string DocUrl(string c) => $"/Documentation/Show?packageId=DMBEffectBuilder&groupName=NuGet&namespaceName=DMBEffectBuilder&objectName={c}";
}

@* --- HEADER --- *@
@using (Html.SectionBuilder().SetHeight(125, UnitSize.px).BootstrapBackgroundEffect(VariantStyle.Normal).Begin())
{
    @using (Html.FlexBlockBuilder().SetAlignItemsCenter().SetJustifyContentCenter().Begin())
    {
        @using (Html.BlockBuilder().AsTextCenter().Begin())
        {
            @Html.TitleBuilder().SetTitle("FX & Ambiance", TitleLevel.One).Render()
            @using (Html.PB_P().AsMuted().Begin())
            {
                @:Overlays, particles and animated layers applied on top of a section
            }
            @Html.Button(ActionItemFactory.Url("Back to Catalog", "/SectionEffect/Index", IconStruct.Bootstrap("bi-arrow-left")).SetVariant(VariantStyle.Primary)).Render()
        }
    }
}

@* --- GRILLE D'EFFETS --- *@
@using (Html.RowBuilder().SetGap(Gap.G4).SetPadding(SpacingSide.X, SpacingSize.Three).SetPadding(SpacingSide.Y, SpacingSize.Four).Begin())
{
    @* 1. Highlight Sweep *@
    @await Html.PartialAsync("_EffectCard", new EffectCardViewModel
    {
        Title = "Highlight Sweep", Icon = "bi-magic",
        Description = "Sweeps a luminous highlight across the section background.",
        Usage = "Hero banners, image headers.",
        EffectAction = s => s.HighlightSweepEffect(0.5m, "/images/test/landscape.png"),
        DocUrl = DocUrl(nameof(HighlightSweepEffect_SectionExtensions))
    })

    @* 2. Noise / Grain *@
    @await Html.PartialAsync("_EffectCard", new EffectCardViewModel
    {
        Title = "Noise / Grain", Icon = "bi-film",
